    "export_confirmation_message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى إنشاء أصول بناءً على الإعدادات الحالية ويتطلب أن يكون التطبيق نشطًا."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Гэта будзе ствараць актывы на аснове бягучых налад і патрабуе актыўнасці праграмы."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil generere aktiver baseret på aktuelle indstillinger og kræver, at appen er aktiv."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden Assets basierend auf den aktuellen Einstellungen generiert. Die App muss dazu aktiv sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will generate assets based on current settings and requires the app to be active."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto generará activos según la configuración actual y requiere que la aplicación esté activa."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bubuo ito ng mga asset batay sa mga kasalukuyang setting at nangangailangan ng app na maging aktibo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela génère des ressources en fonction des paramètres actuels et nécessite que l'application soit active."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "זה ייצור נכסים על סמך ההגדרות הנוכחיות ומחייב את האפליקציה להיות פעילה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह मौजूदा सेटिंग के आधार पर एसेट जेनरेट करेगा और इसके लिए ऐप का सक्रिय होना ज़रूरी है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini akan menghasilkan aset berdasarkan pengaturan saat ini dan mengharuskan aplikasi aktif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo genererà asset in base alle impostazioni correnti e richiede che l'app sia attiva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、現在の設定に基づいてアセットが生成され、アプリがアクティブになっている必要があります。"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini akan menjana aset berdasarkan tetapan semasa dan memerlukan apl untuk aktif."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это сгенерирует активы на основе текущих настроек и требует, чтобы приложение было активным."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การดำเนินการนี้จะสร้างสินทรัพย์ตามการตั้งค่าปัจจุบันและต้องเปิดใช้งานแอป"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將根據當前設定產生資產，並要求應用程式處於活動狀態。"
          }
        }
      }
    },
    "export_confirmation_message_warning" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد يستغرق تصدير كمية كبيرة من الأصول وقتًا أطول ويستنزف البطارية. تأكد من إبقاء التطبيق نشطًا."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Экспарт вялікай колькасці актываў можа заняць больш часу і разрадзіць батарэю. Не забудзьцеся падтрымліваць праграму актыўнай."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eksport af en stor mængde aktiver kan tage længere tid og dræne batteriet. Sørg for at holde appen aktiv."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Exportieren einer großen Menge an Assets kann länger dauern und den Akku belasten. Achten Sie darauf, dass die App aktiv bleibt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exporting a large amount of assets can take longer and drain the battery. Be sure to keep the app active."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportar una gran cantidad de activos puede llevar más tiempo y agotar la batería. Asegúrate de mantener la aplicación activa."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ang pag-export ng malaking halaga ng mga asset ay maaaring magtagal at maubos ang baterya. Tiyaking panatilihing aktibo ang app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'exportation d'une grande quantité de ressources peut prendre plus de temps et épuiser la batterie. Assurez-vous de garder l'application active."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ייצוא כמות גדולה של נכסים עשוי להימשך זמן רב יותר ולרוקן את הסוללה. הקפד לשמור את האפליקציה פעילה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बड़ी मात्रा में एसेट एक्सपोर्ट करने में ज़्यादा समय लग सकता है और बैटरी खत्म हो सकती है। ऐप को सक्रिय रखना सुनिश्चित करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengekspor aset dalam jumlah besar dapat memakan waktu lebih lama dan menguras baterai. Pastikan aplikasi tetap aktif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'esportazione di una grande quantità di asset può richiedere più tempo e scaricare la batteria. Assicurati di mantenere attiva l'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大量のアセットをエクスポートすると、時間がかかり、バッテリーが消耗する可能性があります。アプリをアクティブにしておいてください。"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengeksport sejumlah besar aset boleh mengambil masa yang lebih lama dan menghabiskan bateri. Pastikan apl kekal aktif."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Экспорт большого количества активов может занять больше времени и разрядить аккумулятор. Обязательно держите приложение активным."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การส่งออกสินทรัพย์จำนวนมากอาจใช้เวลานานขึ้นและใช้พลังงานแบตเตอรี่ โปรดเปิดใช้งานแอปอยู่เสมอ"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "導出大量資產可能需要更長時間並耗盡電池電量。請務必保持應用程式處於活動狀態。"
          }
        }
      }
    },

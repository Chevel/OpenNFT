    "settings_mint_address_warning" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحذير - استخدم عنوان محفظة سلسلة Polygon. يمكن أن يؤدي استخدام عناوين أخرى إلى فقدان NFTS."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ПАПЯРЭДЖАННЕ - Выкарыстоўвайце свой адрас кашалька Polygon chain. Выкарыстанне іншых адрасоў можа прывесці да страты NFTS."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ADVARSEL - Brug din Polygon chain wallet-adresse. Brug af andre adresser kan resultere i tabt NFTS."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ACHTUNG – Verwenden Sie die Adresse Ihrer Polygon-Kettenbrieftasche. Die Verwendung anderer Adressen kann zum Verlust von NFTS führen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WARNING - Use your Polygon chain wallet address. Using other addresses can result in lost NFTS."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ADVERTENCIA: use la dirección de su billetera de cadena Polygon. El uso de otras direcciones puede resultar en la pérdida de NFTS."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BABALA - Gamitin ang iyong address ng polygon chain wallet. Ang paggamit ng iba pang mga address ay maaaring magresulta sa pagkawala ng NFTS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AVERTISSEMENT - Utilisez votre adresse de portefeuille de chaîne Polygon. L'utilisation d'autres adresses peut entraîner la perte de NFTS."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אזהרה - השתמש בכתובת ארנק שרשרת Polygon שלך. שימוש בכתובות אחרות עלול לגרום לאיבוד NFTS."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चेतावनी - अपने पॉलीगॉन चेन वॉलेट पते का उपयोग करें। अन्य पतों का उपयोग करने से एनएफटीएस गुम हो सकता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PERINGATAN - Gunakan alamat dompet rantai Polygon Anda. Menggunakan alamat lain dapat menyebabkan NFTS hilang."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ATTENZIONE - Usa l'indirizzo del tuo portafoglio a catena Polygon. L'utilizzo di altri indirizzi può comportare la perdita di NFTS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告 - Polygon チェーン ウォレット アドレスを使用してください。 他のアドレスを使用すると、NFTS が失われる可能性があります。"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AMARAN - Gunakan alamat dompet rantai Polygon anda. Menggunakan alamat lain boleh mengakibatkan NFTS hilang."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ВНИМАНИЕ! Используйте адрес своего сетевого кошелька Polygon. Использование других адресов может привести к потере NFTS."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คำเตือน - ใช้ที่อยู่กระเป๋าเงินห่วงโซ่รูปหลายเหลี่ยมของคุณ การใช้ที่อยู่อื่นอาจทำให้ NFTS สูญหายได้"

    "alert_message_mint_failed" : {
      "extractionState" : "migrated",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فشل سك إلى blockchain. يرجى التحقق من عنوان محفظتك والمحاولة مرة أخرى في وقت لاحق."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Збой чаканкі ў блокчейн. Калі ласка, праверце адрас кашалька і паўтарыце спробу пазней."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Udmøntning til blockchain mislykkedes. Tjek venligst din tegnebogsadresse, og prøv igen senere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Minting zur Blockchain ist fehlgeschlagen. Bitte überprüfen Sie Ihre Wallet-Adresse und versuchen Sie es später erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minting to blockchain failed. Please check your wallet address and try again later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minting a blockchain falló. Verifique la dirección de su billetera e intente nuevamente más tarde."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nabigo ang pag-minting sa blockchain. Pakisuri ang iyong wallet address at subukang muli sa ibang pagkakataon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La frappe vers la blockchain a échoué. Veuillez vérifier l'adresse de votre portefeuille et réessayer plus tard."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ההטבעה לבלוקצ'יין נכשלה. אנא בדוק את כתובת הארנק שלך ונסה שוב מאוחר יותר."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ब्लॉकचैन के लिए खनन विफल रहा। कृपया अपना बटुआ पता जाँचें और बाद में पुनः प्रयास करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mencetak ke blockchain gagal. Harap periksa alamat dompet Anda dan coba lagi nanti."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il conio su blockchain non è riuscito. Controlla l'indirizzo del tuo portafoglio e riprova più tardi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ブロックチェーンへのミントに失敗しました。 ウォレットのアドレスを確認して、後でもう一度お試しください。"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pencetakan kepada blockchain gagal. Sila semak alamat dompet anda dan cuba lagi kemudian."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Минтинг в блокчейн не удался. Пожалуйста, проверьте адрес своего кошелька и повторите попытку позже."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การสร้างเหรียญเพื่อ blockchain ล้มเหลว โปรดตรวจสอบที่อยู่กระเป๋าเงินของคุณแล้วลองอีกครั้งในภายหลัง"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鑄造區塊鏈失敗。 請檢查您的錢包地址，稍後再試。"
          }
        }
      }
    },
